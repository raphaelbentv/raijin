# ───────────────────────────────────────────────────────────────
# Raijin — Environment variables (copy to .env and fill in)
# ───────────────────────────────────────────────────────────────

# ─── Core ─────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
RELEASE_VERSION=local

# ─── Observability ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_RELEASE_VERSION=local

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=raijin
POSTGRES_PASSWORD=raijin_dev_password
POSTGRES_DB=raijin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://raijin:raijin_dev_password@postgres:5432/raijin

# ─── Redis / Celery ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Object storage (MinIO dev / S3 prod) ────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=raijin_dev_access
S3_SECRET_KEY=raijin_dev_secret_key
S3_BUCKET_INVOICES=raijin-invoices
S3_REGION=eu-west-1
S3_SIGNED_URL_TTL_SECONDS=900

# ─── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# ─── Azure Document Intelligence ─────────────────────────────
AZURE_DI_ENDPOINT=https://<resource-name>.cognitiveservices.azure.com/
AZURE_DI_KEY=
AZURE_DI_MODEL=prebuilt-invoice
AZURE_DI_LOCALE=el-GR

# ─── Upload limits ───────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=20
UPLOAD_ALLOWED_MIME=application/pdf,image/jpeg,image/png

# ─── Rate limits ─────────────────────────────────────────────
# Production: 5/10 par minute. E2E/dev: montez à 100-1000.
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_REGISTER_PER_MIN=3

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:6200
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# ─── Encryption (tokens OAuth chiffrés au repos) ─────────────
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── Microsoft Graph (ingestion Outlook) ─────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:6200/integrations/outlook/callback

# ─── Google (Gmail + Drive) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:6200/integrations/google/callback
