ENVIRONMENT=staging
LOG_LEVEL=INFO
RELEASE_VERSION=staging-local

POSTGRES_USER=raijin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=raijin
DATABASE_URL=postgresql+asyncpg://raijin:change-me@postgres:5432/raijin

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

S3_ENDPOINT_URL=https://s3.eu-west-1.amazonaws.com
S3_PUBLIC_URL=https://s3.eu-west-1.amazonaws.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_INVOICES=raijin-staging-invoices
S3_REGION=eu-west-1

JWT_SECRET=
ENCRYPTION_KEY=

FRONTEND_URL=https://staging-raijin.com
NEXT_PUBLIC_API_URL=https://staging-raijin.com/api
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_ENVIRONMENT=staging
NEXT_PUBLIC_RELEASE_VERSION=staging-local

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_DI_MODEL=prebuilt-invoice
AZURE_DI_LOCALE=el-GR

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@staging-raijin.com
SMTP_USE_TLS=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=Raijin Staging <no-reply@staging-raijin.com>

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
OBJECT_BACKUP_URI=s3://raijin-staging-backups/invoices
