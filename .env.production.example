# ───────────────────────────────────────────────────────────────
# Raijin — Production environment (staging / prod)
#
# 1) Générer les secrets :
#      ./scripts/deployment/generate-secrets.sh
# 2) Copier ce fichier puis fusionner avec les secrets :
#      cat .env.production.example .env.production.secrets > .env.production
#      chmod 600 .env.production
# 3) Remplir les URLs et clés API ci-dessous.
# 4) NEVER commit ce fichier.
# ───────────────────────────────────────────────────────────────

ENVIRONMENT=production
LOG_LEVEL=INFO

# ─── Postgres (managed service recommandé : Azure PG, AWS RDS, Scaleway) ──
POSTGRES_USER=raijin_prod
# POSTGRES_PASSWORD — fourni par generate-secrets.sh
POSTGRES_DB=raijin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL doit utiliser POSTGRES_PASSWORD — édite cette ligne
# après génération des secrets avec la vraie valeur.
DATABASE_URL=postgresql+asyncpg://raijin_prod:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/raijin

# ─── Redis (managed Redis recommandé) ──────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Object storage (Azure Blob ou S3 en UE) ───────────────────
S3_ENDPOINT_URL=https://<account>.blob.core.windows.net
S3_ACCESS_KEY=<access_key_fourni_par_provider>
# S3_SECRET_KEY — fourni par generate-secrets.sh pour MinIO local
#                 OU la clé secret de ton provider Azure / AWS
S3_BUCKET_INVOICES=raijin-invoices-prod
S3_REGION=westeurope
S3_SIGNED_URL_TTL_SECONDS=600

# ─── JWT ───────────────────────────────────────────────────────
# JWT_SECRET — fourni par generate-secrets.sh (ne jamais régénérer sans
# invalider tous les tokens existants : les users devront se reconnecter)
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# ─── Encryption at rest (tokens OAuth, credentials ERP/myDATA) ──
# ENCRYPTION_KEY — fourni par generate-secrets.sh
# ⚠️ Si perdue : toutes les intégrations connectées (Outlook, Gmail,
# myDATA, ERP) seront illisibles et devront être reconnectées.

# ─── Azure Document Intelligence ───────────────────────────────
AZURE_DI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=<clé_fournie_par_Azure_portal>
AZURE_DI_MODEL=prebuilt-invoice
AZURE_DI_LOCALE=el-GR

# ─── Microsoft Graph (ingestion Outlook) ───────────────────────
MICROSOFT_CLIENT_ID=<Azure_AD_App_Registration_client_id>
MICROSOFT_CLIENT_SECRET=<Azure_AD_App_Registration_secret_value>
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=https://api.raijin.example.com/integrations/outlook/callback

# ─── Google (Gmail + Drive) ────────────────────────────────────
GOOGLE_CLIENT_ID=<Google_Cloud_OAuth_Client_ID>
GOOGLE_CLIENT_SECRET=<Google_Cloud_OAuth_Secret>
GOOGLE_REDIRECT_URI=https://api.raijin.example.com/integrations/google/callback

# ─── OCR pipeline ──────────────────────────────────────────────
OCR_MAX_RETRIES=3
OCR_RETRY_BACKOFF_SECONDS=30

# ─── Upload limits ─────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=20
UPLOAD_ALLOWED_MIME=application/pdf,image/jpeg,image/png

# ─── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.raijin.example.com
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# ─── CORS (liste d'origines autorisées, séparées par virgule) ───
# Strict en prod : uniquement le domaine front
CORS_ORIGINS=https://app.raijin.example.com

# ─── Sécurité ──────────────────────────────────────────────────
# Taux max de tentatives /auth/login par IP par minute
RATE_LIMIT_LOGIN_PER_MIN=10
# Taux max de /auth/register par IP par minute
RATE_LIMIT_REGISTER_PER_MIN=3

# ─── Observabilité (optionnel) ─────────────────────────────────
# SENTRY_DSN=<https://...ingest.sentry.io/...>
# DATADOG_AGENT_HOST=datadog-agent
